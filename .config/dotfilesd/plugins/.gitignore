# Generated protobuf code — run `make proto` to regenerate
*.pb.go
*.connect.go
# Generated docs embed code (protoc-gen-docs)
*_docs.go
*_docs.json
# Generated doc binary protobuf
*_doc.pb
# Generated markdown docs in proto directories
**/proto/**/*.md
# Compiled plugin binaries (no-extension files in plugin dirs, e.g. htop/htop)
# Re-include files with extensions (source code, configs, assets)
*/*
!*.*
