/*
!/.gitignore
!/.gitmodules

# dotfiles
!/README.md
!/AGENTS.md
!/manu343726.code-workspace
!/.docs/
/.docs/*
!/.docs/*.md

!/.agents/
/.nvm/
!/.zshrc

# vscode configs
!/.vscode/
/.vscode/*
