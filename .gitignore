/*
!/.gitignore
!/.gitmodules

# dotfiles
!/README.md
!/AGENTS.md
!/.docs/
/.docs/*
!/.docs/*.md
!/.agents/
/.nvm/
!/.zshrc
!/.bashrc
!/.profile
!/.xprofile
!/.tmux.conf
!/.tmux.conf.local
!/.dircolors
!/.local/
/.local/*
!/.local/bin/

# dotfilesd source
!/dotfilesd/

# config directories
!/.config/
/.config/*
!/.config/tmux/
/.config/tmux/*
!/.config/tmux/tmux.conf.local
!/.config/kitty/
/.config/kitty/*
!/.config/kitty/kitty.conf
!.i3/
/.i3/*
!/.i3/config
!/.config/i3status/
/.config/i3status/*
!/.config/i3status/config

# opencode MCP config
!/.config/opencode/
/.config/opencode/*
!/.config/opencode/opencode.jsonc
