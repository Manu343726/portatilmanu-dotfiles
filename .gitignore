!/.tmux.conf.local
!/.dircolors
!/.local/
/.local/*
!/.local/bin/
/.local/bin/.dotfilesd.hash
/.local/bin/dotfilesd
/.local/bin/dotfilesctl

# dotfilesd source
!/dotfilesd/

# config directories
!/.config/
/.config/*
