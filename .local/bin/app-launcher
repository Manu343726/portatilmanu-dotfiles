#!/usr/bin/env zsh
#
# app-launcher
# ------------
# Unified launcher with tabbed sections:
#   drun      — desktop apps (native rofi mode)
#   config    — system configuration tools
#   chrome    — Chrome most-visited pages
#
# Switch sections with Ctrl+Tab (or the sidebar).
# Uses the monokai rofi theme.
# Replaces dmenu_recency in the i3 keybinding ($mod+d).
#
# Each custom mode is a separate script that outputs entries for rofi.
# When the user selects an entry in a custom mode, rofi outputs the
# selected display text. This script looks up the display text in the
# mode's item list to find the corresponding action.

theme=/home/manu343726/.config/rofi/monokai.rasi
config_script=app-launcher-config
chrome_script=app-launcher-chrome

selection=$(rofi \
  -modi "drun,config:$config_script,chrome:$chrome_script" \
  -show drun \
  -sidebar-mode \
  -kb-mode-next "Control+Tab" \
  -theme "$theme" 2>/dev/null)

[[ -z "$selection" ]] && exit 0

# ---- Resolve selection to an action ----
# Cache lists from custom modes so we only call each script once.
cfg_items=("${(@f)$($config_script list)}")
cfg_count=$($config_script count)

chrome_items=("${(@f)$($chrome_script list)}")
chrome_count=$($chrome_script count)

action=

for ((i = 0; i < cfg_count; i++)); do
  if [[ "$selection" == "$cfg_items[$((i + 1))]" ]]; then
    action=$($config_script action "$i")
    break
  fi
done

if [[ -z "$action" ]]; then
  for ((i = 0; i < chrome_count; i++)); do
    if [[ "$selection" == "$chrome_items[$((i + 1))]" ]]; then
      action=$($chrome_script action "$i")
      break
    fi
  done
fi

[[ -z "$action" ]] && exit 1

# ---- Dispatch ----
case "$action" in
  cfg:*)
    gtk-launch "${action#cfg:}"
    ;;
  url:*)
    google-chrome-stable "${action#url:}"
    ;;
esac
