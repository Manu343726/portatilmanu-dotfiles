#!/usr/bin/env zsh

ext=$(dotfilesctl display get-outputs 2>/dev/null | sed -n 's/^External: //p')
if [[ -z "$ext" ]]; then
  notify-send "Screen Layout" "No external display detected"
  exit 1
fi

layouts=(
  "Laptop only"
  "External only"
  "Both (extended)"
  "Both (mirror)"
)

choice=$(printf '%s\n' "${layouts[@]}" | rofi -dmenu -p "Screen Layout" -l 4 -theme /home/manu343726/.config/rofi/monokai.rasi)
[[ -z "$choice" ]] && exit 0

case "$choice" in
  "Laptop only")
    dotfilesctl display set-layout --layout=LAPTOP_ONLY
    notify-send "Screen Layout" "Laptop only"
    ;;
  "External only")
    dotfilesctl display set-layout --layout=EXTERNAL_ONLY
    notify-send "Screen Layout" "External only"
    ;;
  "Both (extended)")
    dotfilesctl display set-layout --layout=EXTENDED
    notify-send "Screen Layout" "Both extended"
    ;;
  "Both (mirror)")
    dotfilesctl display set-layout --layout=MIRROR
    notify-send "Screen Layout" "Both mirrored"
    ;;
esac
