{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch dotfilesd (debug build)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/dotfilesd/cmd/dotfilesd",
            "env": {
                "DOTFILESD_PORT": "9105",
                "DOTFILESD_LOG_LEVEL": "debug"
            },
            "args": [],
            "showLog": true,
            "preLaunchTask": {
                "label": "stop-dotfilesd-service",
                "type": "shell",
                "command": "systemctl --user stop dotfilesd.service",
                "problemMatcher": []
            },
            "postDebugTask": {
                "label": "start-dotfilesd-service",
                "type": "shell",
                "command": "systemctl --user start dotfilesd.service",
                "problemMatcher": []
            }
        },
        {
            "name": "Launch dotfilesd (custom port, no service conflict)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/dotfilesd/cmd/dotfilesd",
            "env": {
                "DOTFILESD_PORT": "9106",
                "DOTFILESD_LOG_LEVEL": "debug"
            },
            "args": [],
            "showLog": true
        },
        {
            "name": "Attach to dotfilesd",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "processId": "${command:pickGoProcess}",
            "showLog": true
        }
    ]
}
